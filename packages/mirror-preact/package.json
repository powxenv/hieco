{
  "name": "@hieco/mirror-preact",
  "version": "1.0.0",
  "description": "Type-safe Preact hooks for Hedera Mirror Node with TanStack Query",
  "keywords": [
    "hedera",
    "hooks",
    "mirror-node",
    "preact",
    "tanstack-query"
  ],
  "homepage": "https://github.com/powxenv/hieco/tree/main/packages/mirror-preact",
  "bugs": {
    "url": "https://github.com/powxenv/hieco/issues"
  },
  "license": "MIT",
  "author": "pow <https://github.com/powxenv>",
  "repository": {
    "type": "git",
    "url": "https://github.com/powxenv/hieco",
    "directory": "packages/mirror-preact"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "workerd": "./dist/index.js",
      "worker": "./dist/index.js",
      "browser": "./dist/index.js",
      "node": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun run ./build.ts && tsc -p tsconfig.build.json",
    "dev": "bun --watch ./build.ts",
    "typecheck": "tsgo --noEmit --project tsconfig.typecheck.json",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --fix --type-aware",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "dependencies": {
    "@hieco/mirror": "^1.0.0",
    "@hieco/utils": "^1.0.0"
  },
  "devDependencies": {
    "@typescript/native-preview": "catalog:",
    "bun-types": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "preact": "^10.0.0",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "@hieco/mirror": "^1.0.0",
    "@hieco/utils": "^1.0.0",
    "@tanstack/preact-query": "^5.0.0",
    "preact": ">=10"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
