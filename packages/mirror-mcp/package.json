{
  "name": "@hieco/mirror-mcp",
  "version": "0.0.1",
  "description": "MCP server for Hedera Mirror Node REST API",
  "keywords": [
    "agents",
    "hedera",
    "mcp",
    "mirror-node",
    "tools"
  ],
  "homepage": "https://github.com/powxenv/hieco/tree/main/packages/mirror-mcp",
  "bugs": {
    "url": "https://github.com/powxenv/hieco/issues"
  },
  "license": "MIT",
  "author": "pow <https://github.com/powxenv>",
  "repository": {
    "type": "git",
    "url": "https://github.com/powxenv/hieco",
    "directory": "packages/mirror-mcp"
  },
  "bin": {
    "mirror-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun run ./build.ts",
    "dev": "bun --watch ./build.ts",
    "typecheck": "tsgo --noEmit --project tsconfig.typecheck.json",
    "lint": "oxlint --type-aware",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "inspect": "bunx @modelcontextprotocol/inspector node dist/index.js"
  },
  "dependencies": {
    "@hieco/mirror": "^0.0.1",
    "@hieco/utils": "^0.0.1",
    "@mastra/core": "^1.0.0",
    "@mastra/mcp": "^1.0.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@typescript/native-preview": "catalog:",
    "bun-types": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
