{
  "name": "@hieco/mirror-mcp",
  "version": "0.0.1",
  "description": "MCP server for Hedera Mirror Node REST API",
  "bin": {
    "mirror-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun run ./build.ts",
    "dev": "bun --watch ./build.ts",
    "typecheck": "tsgo --noEmit --project tsconfig.typecheck.json",
    "lint": "oxlint --type-aware",
    "fmt": "oxfmt",
    "inspect": "bunx @modelcontextprotocol/inspector node dist/index.js"
  },
  "dependencies": {
    "@hieco/mirror": "workspace:*",
    "@hieco/utils": "workspace:*",
    "@mastra/core": "^1.0.0",
    "@mastra/mcp": "^1.0.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@typescript/native-preview": "catalog:",
    "bun-types": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
