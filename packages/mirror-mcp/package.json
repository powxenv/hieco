{
  "name": "@hiecom/mirror-mcp",
  "version": "0.0.1",
  "description": "MCP server for Hedera Mirror Node REST API",
  "bin": {
    "mirror-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun build ./src/mastra/index.ts --outdir ./dist --target node --format esm --sourcemap && { printf '%s\\n' '#!/usr/bin/env node' | cat - dist/index.js > dist/index.tmp && mv dist/index.tmp dist/index.js; } && chmod +x dist/index.js",
    "dev": "bun build ./src/mastra/index.ts --outdir ./dist --target node --format esm --watch",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint --type-aware",
    "fmt": "oxfmt",
    "inspect": "bunx @modelcontextprotocol/inspector node dist/index.js"
  },
  "dependencies": {
    "@hiecom/mirror-js": "workspace:*",
    "@hiecom/mirror-shared": "workspace:*",
    "@hiecom/types": "workspace:*",
    "@mastra/core": "^1.0.0",
    "@mastra/mcp": "^1.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.1",
    "@typescript/native-preview": "^7.0.0-dev.20260222.1",
    "oxfmt": "^0.34.0",
    "oxlint": "^1.49.0",
    "oxlint-tsgolint": "^0.15.0"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
