{
  "name": "@hieco/realtime",
  "version": "0.0.1",
  "description": "Real-time streaming client for Hedera Mirror Node via HIP-694 JSON-RPC Relay",
  "keywords": [
    "hedera",
    "hip-694",
    "json-rpc-relay",
    "mirror-node",
    "realtime",
    "streaming",
    "websocket"
  ],
  "homepage": "https://github.com/powxenv/hieco/tree/main/packages/realtime",
  "bugs": {
    "url": "https://github.com/powxenv/hieco/issues"
  },
  "license": "MIT",
  "author": "pow <https://github.com/powxenv>",
  "repository": {
    "type": "git",
    "url": "https://github.com/powxenv/hieco",
    "directory": "packages/realtime"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun run ./build.ts && bunx tsc -p tsconfig.build.json",
    "dev": "bun --watch ./build.ts",
    "typecheck": "tsgo --noEmit --project tsconfig.test.json",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --fix --type-aware",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "devDependencies": {
    "@typescript/native-preview": "catalog:",
    "bun-types": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:"
  },
  "peerDependencies": {
    "@hieco/mirror": "workspace:*",
    "@hieco/utils": "workspace:*"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
