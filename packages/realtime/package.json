{
  "name": "@hieco/realtime",
  "version": "0.0.1",
  "description": "Real-time streaming client for Hedera Mirror Node via HIP-694 JSON-RPC Relay",
  "keywords": [
    "hedera",
    "hip-694",
    "json-rpc-relay",
    "mirror-node",
    "realtime",
    "streaming",
    "websocket"
  ],
  "homepage": "https://github.com/powxenv/hieco/tree/main/packages/realtime",
  "bugs": {
    "url": "https://github.com/powxenv/hieco/issues"
  },
  "license": "MIT",
  "author": "pow <https://github.com/powxenv>",
  "repository": {
    "type": "git",
    "url": "https://github.com/powxenv/hieco",
    "directory": "packages/realtime"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target node --format esm --sourcemap --external @hieco/mirror-js && bunx tsc --emitDeclarationOnly --declaration --outDir dist",
    "dev": "bun build ./src/index.ts --outdir ./dist --target node --format esm --watch --external @hieco/mirror-js",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --fix --type-aware",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "devDependencies": {
    "@typescript/native-preview": "^7.0.0-dev.20260222.1",
    "bun-types": "^1.3.9",
    "oxfmt": "^0.34.0",
    "oxlint": "^1.49.0",
    "oxlint-tsgolint": "^0.14.2"
  },
  "peerDependencies": {
    "@hieco/mirror-js": "workspace:*",
    "@hieco/types": "workspace:*"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
