{
  "name": "@hieco/utils",
  "version": "0.0.1",
  "private": true,
  "description": "Shared internal utilities and types for hieco packages",
  "keywords": [
    "hedera",
    "types",
    "typescript",
    "utils"
  ],
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "bun run ./build.ts && tsc -p tsconfig.build.json",
    "dev": "bun --watch ./build.ts",
    "typecheck": "tsgo --noEmit --project tsconfig.test.json",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --fix --type-aware",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "devDependencies": {
    "@tanstack/query-core": "^5.67.1",
    "@typescript/native-preview": "catalog:",
    "bun-types": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "@tanstack/query-core": "^5.67.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
