{
  "name": "@hieco/utils",
  "version": "0.0.1",
  "description": "Shared utilities and types for Hieco packages",
  "keywords": [
    "hedera",
    "types",
    "typescript",
    "utils"
  ],
  "homepage": "https://github.com/powxenv/hieco/tree/main/packages/utils",
  "bugs": {
    "url": "https://github.com/powxenv/hieco/issues"
  },
  "license": "MIT",
  "author": "pow <https://github.com/powxenv>",
  "repository": {
    "type": "git",
    "url": "https://github.com/powxenv/hieco",
    "directory": "packages/utils"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "workerd": "./dist/index.js",
      "worker": "./dist/index.js",
      "browser": "./dist/index.js",
      "node": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./entity": {
      "types": "./dist/exports/entity.d.ts",
      "import": "./dist/exports/entity.js",
      "workerd": "./dist/exports/entity.js",
      "worker": "./dist/exports/entity.js",
      "browser": "./dist/exports/entity.js",
      "node": "./dist/exports/entity.js",
      "default": "./dist/exports/entity.js"
    },
    "./network": {
      "types": "./dist/exports/network.d.ts",
      "import": "./dist/exports/network.js",
      "workerd": "./dist/exports/network.js",
      "worker": "./dist/exports/network.js",
      "browser": "./dist/exports/network.js",
      "node": "./dist/exports/network.js",
      "default": "./dist/exports/network.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun run ./build.ts && tsc -p tsconfig.build.json",
    "dev": "bun --watch ./build.ts",
    "typecheck": "tsgo --noEmit --project tsconfig.typecheck.json",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --fix --type-aware",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "devDependencies": {
    "@tanstack/query-core": "^5.67.1",
    "@typescript/native-preview": "catalog:",
    "bun-types": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "@tanstack/query-core": "^5.67.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
