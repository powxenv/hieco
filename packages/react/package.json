{
  "name": "@hieco/react",
  "version": "0.0.1",
  "description": "React hooks for @hieco/sdk with TanStack Query",
  "keywords": [
    "hedera",
    "hiero",
    "hooks",
    "react",
    "sdk",
    "tanstack-query"
  ],
  "homepage": "https://github.com/powxenv/hieco/tree/main/packages/react",
  "bugs": {
    "url": "https://github.com/powxenv/hieco/issues"
  },
  "license": "MIT",
  "author": "pow <https://github.com/powxenv>",
  "repository": {
    "type": "git",
    "url": "https://github.com/powxenv/hieco",
    "directory": "packages/react"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "workerd": "./dist/index.js",
      "worker": "./dist/index.js",
      "browser": "./dist/index.js",
      "node": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./appkit": {
      "types": "./dist/appkit/index.d.ts",
      "import": "./dist/appkit/index.js",
      "workerd": "./dist/appkit/index.js",
      "worker": "./dist/appkit/index.js",
      "browser": "./dist/appkit/index.js",
      "node": "./dist/appkit/index.js",
      "default": "./dist/appkit/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun run generate && bun run ./build.ts && tsc -p tsconfig.build.json",
    "dev": "bun run generate && bun --watch ./build.ts",
    "generate": "bun ./scripts/generate-hooks.ts",
    "typecheck": "tsgo --noEmit --project tsconfig.typecheck.json",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --fix --type-aware",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "dependencies": {
    "@hieco/sdk": "workspace:*",
    "@hieco/utils": "workspace:*"
  },
  "devDependencies": {
    "@hashgraph/hedera-wallet-connect": "2.0.6",
    "@reown/appkit": "1.8.19",
    "@types/react": "catalog:react",
    "@types/react-dom": "catalog:react",
    "@typescript/native-preview": "catalog:",
    "@walletconnect/universal-provider": "2.23.7",
    "bun-types": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "react": "catalog:react",
    "react-dom": "catalog:react",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "@hashgraph/hedera-wallet-connect": "^2.0.6",
    "@hieco/sdk": "workspace:*",
    "@reown/appkit": "^1.8.19",
    "@tanstack/react-query": "^5.0.0",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "@hashgraph/hedera-wallet-connect": {
      "optional": true
    },
    "@reown/appkit": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
