{
  "name": "@hiecom/solid-mirror-node",
  "version": "0.0.1",
  "description": "Type-safe SolidJS hooks for Hedera Mirror Node",
  "keywords": [
    "hedera",
    "hooks",
    "mirror-node",
    "solidjs"
  ],
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tanstack-query": {
      "types": "./dist/adapters/tanstack-query/index.d.ts",
      "import": "./dist/adapters/tanstack-query/index.js"
    }
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target node --format esm --sourcemap --external solid-js --external @tanstack/solid-query --external @hiecom/mirror-node && bunx tsc --emitDeclarationOnly --declaration --outDir dist",
    "dev": "bun build ./src/index.ts --outdir ./dist --target node --format esm --watch --external solid-js --external @tanstack/solid-query --external @hiecom/mirror-node",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --fix --type-aware",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "devDependencies": {
    "@typescript/native-preview": "^7.0.0-dev.20260222.1",
    "bun-types": "^1.3.9",
    "oxfmt": "^0.34.0",
    "oxlint": "^1.49.0",
    "oxlint-tsgolint": "^0.14.2"
  },
  "peerDependencies": {
    "@hiecom/mirror-node": "workspace:*",
    "@tanstack/solid-query": "^5.0.0",
    "solid-js": ">=1.8"
  }
}
