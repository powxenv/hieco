{
  "name": "@hiecom/testing",
  "version": "0.0.1",
  "description": "Testing utilities for Hedera Mirror Node development with MSW fixtures and helpers",
  "keywords": [
    "hedera",
    "mirror-node",
    "testing",
    "test-utils",
    "msw",
    "mock-service-worker",
    "fixtures"
  ],
  "license": "MIT",
  "author": "pow <https://github.com/powxenv>",
  "repository": {
    "type": "git",
    "url": "https://github.com/powxenv/hiecom",
    "directory": "packages/testing"
  },
  "homepage": "https://github.com/powxenv/hiecom/tree/main/packages/testing",
  "bugs": {
    "url": "https://github.com/powxenv/hiecom/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./fixtures": {
      "types": "./dist/fixtures/index.d.ts",
      "import": "./dist/fixtures/index.js"
    }
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target node --format esm --sourcemap --external msw && bunx tsc --emitDeclarationOnly --declaration --outDir dist",
    "dev": "bun build ./src/index.ts --outdir ./dist --target node --format esm --watch --external msw",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --fix --type-aware",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "test": "bun test",
    "test:coverage": "bun test --coverage"
  },
  "dependencies": {
    "@hiecom/mirror-js": "workspace:*",
    "@hiecom/mirror-shared": "workspace:*"
  },
  "devDependencies": {
    "bun-types": "^1.3.9",
    "msw": "^2.7.0",
    "oxfmt": "^0.34.0",
    "oxlint": "^1.49.0",
    "oxlint-tsgolint": "^0.15.0",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "msw": "^2.7.0"
  }
}
