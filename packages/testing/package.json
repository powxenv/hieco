{
  "name": "@hieco/testing",
  "version": "0.0.1",
  "description": "Comprehensive testing library for Hiero blockchain development with mock client, fixtures, and custom matchers",
  "keywords": [
    "fixtures",
    "hiero",
    "hiero-sdk",
    "jest",
    "matchers",
    "mock",
    "mock-client",
    "testing",
    "testkit",
    "vitest"
  ],
  "homepage": "https://github.com/powxenv/hieco/tree/main/packages/testing",
  "bugs": {
    "url": "https://github.com/powxenv/hieco/issues"
  },
  "license": "MIT",
  "author": "pow <https://github.com/powxenv>",
  "repository": {
    "type": "git",
    "url": "https://github.com/powxenv/hieco",
    "directory": "packages/testing"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./fixtures": {
      "types": "./dist/fixtures/index.d.ts",
      "import": "./dist/fixtures/index.js"
    },
    "./hiero": {
      "types": "./dist/hiero/index.d.ts",
      "import": "./dist/hiero/index.js"
    },
    "./matchers": {
      "types": "./dist/matchers/index.d.ts",
      "import": "./dist/matchers/index.js"
    },
    "./testkit": {
      "types": "./dist/testkit/index.d.ts",
      "import": "./dist/testkit/index.js"
    },
    "./vitest": {
      "types": "./dist/vitest/index.d.ts",
      "import": "./dist/vitest/index.js"
    },
    "./jest": {
      "types": "./dist/jest/index.d.ts",
      "import": "./dist/jest/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target node --format esm --sourcemap --external msw && bunx tsc --emitDeclarationOnly --declaration --outDir dist",
    "dev": "bun build ./src/index.ts --outdir ./dist --target node --format esm --watch --external msw",
    "typecheck": "tsgo --noEmit --project tsconfig.test.json",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --fix --type-aware",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "test": "bun test",
    "test:coverage": "bun test --coverage"
  },
  "dependencies": {
    "@hieco/mirror": "workspace:*",
    "@hieco/mirror-shared": "workspace:*"
  },
  "devDependencies": {
    "@hiero-ledger/sdk": "^2.80.0",
    "@types/jest": "^29.5.12",
    "@typescript/native-preview": "catalog:",
    "bun-types": "catalog:",
    "jest": "^29.7.0",
    "msw": "^2.7.0",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "tsafe": "^1.8.12",
    "vitest": "^2.1.0"
  },
  "peerDependencies": {
    "@hiero-ledger/sdk": "^2.0.0",
    "msw": "^2.7.0"
  },
  "peerDependenciesMeta": {
    "@hiero-ledger/sdk": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
