{
  "name": "@hiecom/solid-mirror-node",
  "version": "0.0.1",
  "description": "Type-safe SolidJS signals for Hedera Mirror Node",
  "keywords": [
    "hedera",
    "signals",
    "mirror-node",
    "solid",
    "solidjs"
  ],
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./solid-query": {
      "types": "./dist/adapters/solid-query/index.d.ts",
      "import": "./dist/adapters/solid-query/index.js"
    }
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target node --format esm --sourcemap --external solid-js --external @hiecom/mirror-node --external @tanstack/solid-query && bunx tsc --emitDeclarationOnly --declaration --outDir dist",
    "dev": "bun build ./src/index.ts --outdir ./dist --target node --format esm --watch --external solid-js --external @hiecom/mirror-node --external @tanstack/solid-query",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --fix --type-aware",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "devDependencies": {
    "@typescript/native-preview": "^7.0.0-dev.20260222.1",
    "bun-types": "^1.3.9",
    "oxfmt": "^0.34.0",
    "oxlint": "^1.49.0",
    "oxlint-tsgolint": "^0.14.2",
    "solid-js": "^1.9.5"
  },
  "peerDependencies": {
    "@hiecom/mirror-node": "workspace:*",
    "@tanstack/solid-query": "^5.0.0",
    "solid-js": ">=1.9"
  },
  "dependencies": {
    "solid-js": "^1.9.5"
  }
}
