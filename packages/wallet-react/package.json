{
  "name": "@hieco/wallet-react",
  "version": "0.0.1",
  "description": "React bindings for @hieco/wallet",
  "keywords": [
    "hedera",
    "hiero",
    "react",
    "wallet",
    "walletconnect",
    "web3"
  ],
  "homepage": "https://github.com/powxenv/hieco/tree/main/packages/wallet-react",
  "bugs": {
    "url": "https://github.com/powxenv/hieco/issues"
  },
  "license": "MIT",
  "author": "pow <https://github.com/powxenv>",
  "repository": {
    "type": "git",
    "url": "https://github.com/powxenv/hieco",
    "directory": "packages/wallet-react"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typings": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "workerd": "./dist/index.js",
      "worker": "./dist/index.js",
      "browser": "./dist/index.js",
      "node": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun run ./build.ts && tsc -p tsconfig.build.json",
    "dev": "bun --watch ./build.ts",
    "typecheck": "tsgo --noEmit --project tsconfig.typecheck.json",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --fix --type-aware",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "dependencies": {
    "@hieco/wallet": "^0.0.1"
  },
  "devDependencies": {
    "@hiero-ledger/sdk": "^2.80.0",
    "@types/react": "catalog:react",
    "@types/react-dom": "catalog:react",
    "@typescript/native-preview": "catalog:",
    "bun-types": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "react": "catalog:react",
    "react-dom": "catalog:react",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "@hieco/wallet": "^0.0.1",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
