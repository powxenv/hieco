{
  "name": "@hieco/wallet-react",
  "version": "0.0.1",
  "description": "React bindings and optional UI for @hieco/wallet",
  "keywords": [
    "hedera",
    "hiero",
    "react",
    "wallet",
    "walletconnect",
    "web3"
  ],
  "homepage": "https://github.com/powxenv/hieco/tree/main/packages/wallet-react",
  "bugs": {
    "url": "https://github.com/powxenv/hieco/issues"
  },
  "license": "MIT",
  "author": "pow <https://github.com/powxenv>",
  "repository": {
    "type": "git",
    "url": "https://github.com/powxenv/hieco",
    "directory": "packages/wallet-react"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typings": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "ui": [
        "./dist/ui/index.d.ts"
      ],
      "*": [
        "./dist/*"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./ui": {
      "types": "./dist/ui/index.d.ts",
      "import": "./dist/ui/index.js",
      "require": "./dist/ui/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build && bunx tsc -p tsconfig.build.json",
    "dev": "vite build --watch",
    "typecheck": "tsgo --noEmit --project tsconfig.test.json",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --fix --type-aware",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "test": "bun test"
  },
  "dependencies": {
    "@hieco/wallet": "workspace:*",
    "@nanostores/react": "^1.0.0",
    "@stylexjs/stylex": "0.18.1",
    "qrcode": "1.5.3"
  },
  "devDependencies": {
    "@hiero-ledger/sdk": "^2.80.0",
    "@stylexjs/unplugin": "0.18.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "catalog:react",
    "@types/react-dom": "catalog:react",
    "@typescript/native-preview": "catalog:",
    "@vitejs/plugin-react": "^5.1.1",
    "bun-types": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "react": "catalog:react",
    "react-dom": "catalog:react",
    "vite": "^8.0.0-beta.13"
  },
  "peerDependencies": {
    "@hieco/wallet": "workspace:*",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "overrides": {
    "vite": "^8.0.0-beta.13"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
