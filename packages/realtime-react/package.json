{
  "name": "@hieco/realtime-react",
  "version": "0.0.1",
  "description": "React hooks for @hieco/realtime with automatic subscription management",
  "keywords": [
    "hedera",
    "hip-694",
    "hooks",
    "json-rpc-relay",
    "react",
    "realtime",
    "websocket"
  ],
  "homepage": "https://github.com/powxenv/hieco/tree/main/packages/realtime-react",
  "bugs": {
    "url": "https://github.com/powxenv/hieco/issues"
  },
  "license": "MIT",
  "author": "pow <https://github.com/powxenv>",
  "repository": {
    "type": "git",
    "url": "https://github.com/powxenv/hieco",
    "directory": "packages/realtime-react"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "workerd": "./dist/index.js",
      "worker": "./dist/index.js",
      "browser": "./dist/index.js",
      "node": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun run ./build.ts && tsc -p tsconfig.build.json",
    "dev": "bun --watch ./build.ts",
    "typecheck": "tsgo --noEmit --project tsconfig.typecheck.json",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --fix --type-aware",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "dependencies": {
    "@hieco/mirror": "^0.0.1",
    "@hieco/realtime": "^0.0.1"
  },
  "devDependencies": {
    "@types/react": "catalog:react",
    "@types/react-dom": "catalog:react",
    "@typescript/native-preview": "catalog:",
    "bun-types": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "react": "catalog:react",
    "react-dom": "catalog:react",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "@hieco/mirror": "^0.0.1",
    "@hieco/realtime": "^0.0.1",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
