{
  "name": "@hiecom/realtime-react",
  "version": "0.0.1",
  "description": "React hooks for @hiecom/realtime",
  "keywords": [
    "hedera",
    "hip-694",
    "json-rpc-relay",
    "realtime",
    "react",
    "hooks"
  ],
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target node --format esm --sourcemap --external react --external react-dom --external @hiecom/mirror-js --external @hiecom/realtime && bunx tsc --emitDeclarationOnly --declaration --outDir dist",
    "dev": "bun build ./src/index.ts --outdir ./dist --target node --format esm --watch --external react --external react-dom --external @hiecom/mirror-js --external @hiecom/realtime",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --fix --type-aware",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript/native-preview": "^7.0.0-dev.20260222.1",
    "bun-types": "^1.3.9",
    "oxfmt": "^0.34.0",
    "oxlint": "^1.49.0",
    "oxlint-tsgolint": "^0.14.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "peerDependencies": {
    "@hiecom/mirror-js": "workspace:*",
    "@hiecom/realtime": "workspace:*",
    "react": ">=18",
    "react-dom": ">=18"
  }
}
