{
  "name": "@hieco/mirror-cli",
  "version": "0.0.1",
  "description": "CLI tool for Hedera Mirror Node REST API - query accounts, tokens, transactions, blocks, contracts, schedules, topics, and network state",
  "keywords": [
    "blockchain",
    "cli",
    "command-line",
    "hbar",
    "hedera",
    "mirror-node",
    "rest-api"
  ],
  "homepage": "https://github.com/powxenv/hieco/tree/main/packages/mirror-cli",
  "bugs": {
    "url": "https://github.com/powxenv/hieco/issues"
  },
  "license": "MIT",
  "author": "pow <https://github.com/powxenv>",
  "repository": {
    "type": "git",
    "url": "https://github.com/powxenv/hieco",
    "directory": "packages/mirror-cli"
  },
  "bin": {
    "hieco": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun run ./build.ts",
    "dev": "bun --watch ./build.ts",
    "typecheck": "tsgo --noEmit --project tsconfig.typecheck.json",
    "lint": "oxlint --type-aware",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "dependencies": {
    "@hieco/mirror": "workspace:*",
    "@hieco/utils": "workspace:*",
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@typescript/native-preview": "catalog:",
    "bun-types": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
