{
  "name": "@hieco/runtime",
  "version": "1.0.0",
  "description": "Runtime-aware Hiero SDK adapter for browser, workers, and Node.js",
  "keywords": [
    "hedera",
    "hiero",
    "runtime",
    "sdk",
    "workers"
  ],
  "homepage": "https://github.com/powxenv/hieco/tree/main/packages/runtime",
  "bugs": {
    "url": "https://github.com/powxenv/hieco/issues"
  },
  "license": "MIT",
  "author": "pow <https://github.com/powxenv>",
  "repository": {
    "type": "git",
    "url": "https://github.com/powxenv/hieco",
    "directory": "packages/runtime"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/node.js",
  "module": "./dist/browser.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "workerd": "./dist/browser.js",
      "worker": "./dist/browser.js",
      "browser": "./dist/browser.js",
      "node": "./dist/node.js",
      "default": "./dist/browser.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun run ./build.ts && bunx tsc -p tsconfig.build.json",
    "dev": "bun --watch ./build.ts",
    "typecheck": "bunx tsgo --noEmit --project tsconfig.typecheck.json",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --fix --type-aware",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "dependencies": {
    "@hiero-ledger/sdk": "^2.80.0"
  },
  "devDependencies": {
    "@typescript/native-preview": "catalog:",
    "bun-types": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
