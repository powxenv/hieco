{
  "name": "web",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 5878",
    "build": "cd ../.. && bun run build:utils && bun run build:wallet && bun run build:wallet-react && cd apps/web && vite build",
