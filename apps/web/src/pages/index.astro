---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
    title="Hieco — Say Hello Future to Better Hedera Development"
    description="The abstraction layer between your code and the Hedera network. Handles the SDK wiring so you can focus on shipping."
>
    <header class="border-b border-zinc-200 fixed top-0 inset-x-0 bg-white">
        <div class="inner">
            <div class="px-8">
                Lorem ipsum dolor sit amet consectetur adipisicing elit. Eligendi omnis in facilis veritatis nesciunt
                obcaecati delectus voluptatem. Nulla quam officia blanditiis explicabo fugiat, at aspernatur, sed totam
                est quasi rerum.
            </div>
        </div>
    </header>
    <main class="">
        <div class="inner">
            <div class="border-x border-zinc-200 min-h-lvh flex items-center">
                <div class="grid grid-cols-2 gap-10">
                    <div class="flex flex-col gap-4 p-8">
                        <h1 class="text-7xl">
                            Say <span
                                class="bg-linear-to-b from-indigo-600 to-purple-600 text-transparent bg-clip-text"
                            >
                                Hello Future
                            </span> to Better Hedera Development
                        </h1>
                        <p class="mt-4 text-2xl text-gray-600">
                            The abstraction layer between your code and the Hedera network. Handles the SDK wiring so
                            you can focus on shipping.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </main>
</BaseLayout>
