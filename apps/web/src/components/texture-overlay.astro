---
interface Props {
	class?: string;
}

const { class: className = "" } = Astro.props;
---

<div
	aria-hidden="true"
	class="pointer-events-none absolute inset-0 z-0 text-zinc-300 {className}"
>
	<div
		class="absolute inset-0 bg-current contain-paint"
		style='will-change: mask-image; mask-image: url("data:image/png;base64,"); mask-repeat: repeat; mask-size: 16px 16px; mask-position: center top;'
	>
	</div>
	<div
		class="absolute inset-0 bg-zinc-600 contain-paint"
		style='will-change: mask-image; mask-image: url("data:image/png;base64,"); mask-repeat: repeat; mask-size: 16px 16px; mask-position: center top;'
	>
	</div>
</div>
