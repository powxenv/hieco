{
  "name": "hieco",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*",
    "examples/*"
  ],
  "scripts": {
    "fmt": "oxfmt && bun --filter '*' fmt",
    "fmt:mirror-js": "bun --filter '@hieco/mirror-js' fmt",
    "fmt:mirror-cli": "bun --filter '@hieco/mirror-cli' fmt",
    "fmt:mirror-mcp": "bun --filter '@hieco/mirror-mcp' fmt",
    "fmt:mirror-react": "bun --filter '@hieco/mirror-react' fmt",
    "fmt:mirror-solid": "bun --filter '@hieco/mirror-solid' fmt",
    "fmt:mirror-preact": "bun --filter '@hieco/mirror-preact' fmt",
    "fmt:mirror-shared": "bun --filter '@hieco/mirror-shared' fmt",
    "fmt:testing": "bun --filter '@hieco/testing' fmt",
    "fmt:realtime": "bun --filter '@hieco/realtime' fmt",
    "fmt:realtime-react": "bun --filter '@hieco/realtime-react' fmt",
    "fmt:types": "bun --filter '@hieco/types' fmt",
    "lint": "oxlint --type-aware && bun --filter '*' lint",
    "lint:mirror-js": "bun --filter '@hieco/mirror-js' lint",
    "lint:mirror-cli": "bun --filter '@hieco/mirror-cli' lint",
    "lint:mirror-mcp": "bun --filter '@hieco/mirror-mcp' lint",
    "lint:mirror-react": "bun --filter '@hieco/mirror-react' lint",
    "lint:mirror-solid": "bun --filter '@hieco/mirror-solid' lint",
    "lint:mirror-preact": "bun --filter '@hieco/mirror-preact' lint",
    "lint:mirror-shared": "bun --filter '@hieco/mirror-shared' lint",
    "lint:testing": "bun --filter '@hieco/testing' lint",
    "lint:realtime": "bun --filter '@hieco/realtime' lint",
    "lint:realtime-react": "bun --filter '@hieco/realtime-react' lint",
    "lint:types": "bun --filter '@hieco/types' lint",
    "typecheck": "bun --filter '*' typecheck",
    "typecheck:mirror-js": "bun --filter '@hieco/mirror-js' typecheck",
    "typecheck:mirror-cli": "bun --filter '@hieco/mirror-cli' typecheck",
    "typecheck:mirror-mcp": "bun --filter '@hieco/mirror-mcp' typecheck",
    "typecheck:mirror-react": "bun --filter '@hieco/mirror-react' typecheck",
    "typecheck:mirror-solid": "bun --filter '@hieco/mirror-solid' typecheck",
    "typecheck:mirror-preact": "bun --filter '@hieco/mirror-preact' typecheck",
    "typecheck:mirror-shared": "bun --filter '@hieco/mirror-shared' typecheck",
    "typecheck:testing": "bun --filter '@hieco/testing' typecheck",
    "typecheck:realtime": "bun --filter '@hieco/realtime' typecheck",
    "typecheck:realtime-react": "bun --filter '@hieco/realtime-react' typecheck",
    "typecheck:types": "bun --filter '@hieco/types' typecheck",
    "build": "bun --filter '*' build",
    "build:mirror-js": "bun --filter '@hieco/mirror-js' build",
    "build:mirror-cli": "bun --filter '@hieco/mirror-cli' build",
    "build:mirror-mcp": "bun --filter '@hieco/mirror-mcp' build",
    "build:mirror-react": "bun --filter '@hieco/mirror-react' build",
    "build:mirror-solid": "bun --filter '@hieco/mirror-solid' build",
    "build:mirror-preact": "bun --filter '@hieco/mirror-preact' build",
    "build:mirror-shared": "bun --filter '@hieco/mirror-shared' build",
    "build:testing": "bun --filter '@hieco/testing' build",
    "build:realtime": "bun --filter '@hieco/realtime' build",
    "build:realtime-react": "bun --filter '@hieco/realtime-react' build",
    "build:types": "bun --filter '@hieco/types' build",
    "test": "bun --filter '*' test",
    "test:testing": "bun --filter '@hieco/testing' test",
    "dev:web": "bun --filter '@hieco/web' dev"
  },
  "devDependencies": {
    "oxfmt": "^0.34.0",
    "oxlint": "^1.50.0",
    "oxlint-tsgolint": "^0.15.0"
  }
}
