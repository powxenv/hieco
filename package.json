{
    "name": "hiecom",
    "private": true,
    "workspaces": [
        "packages/*",
        "apps/*",
        "examples/*"
    ],
    "scripts": {
        "fmt": "bun --filter '*' fmt",
        "fmt:mirror-js": "bun --filter '@hiecom/mirror-js' fmt",
        "fmt:mirror-react": "bun --filter '@hiecom/mirror-react' fmt",
        "fmt:mirror-solid": "bun --filter '@hiecom/mirror-solid' fmt",
        "fmt:mirror-preact": "bun --filter '@hiecom/mirror-preact' fmt",
        "fmt:mirror-shared": "bun --filter '@hiecom/mirror-shared' fmt",
        "fmt:testing": "bun --filter '@hiecom/testing' fmt",
        "lint": "bun --filter '*' lint",
        "lint:mirror-js": "bun --filter '@hiecom/mirror-js' lint",
        "lint:mirror-react": "bun --filter '@hiecom/mirror-react' lint",
        "lint:mirror-solid": "bun --filter '@hiecom/mirror-solid' lint",
        "lint:mirror-preact": "bun --filter '@hiecom/mirror-preact' lint",
        "lint:mirror-shared": "bun --filter '@hiecom/mirror-shared' lint",
        "lint:testing": "bun --filter '@hiecom/testing' lint",
        "typecheck": "bun --filter '*' typecheck",
        "typecheck:mirror-js": "bun --filter '@hiecom/mirror-js' typecheck",
        "typecheck:mirror-react": "bun --filter '@hiecom/mirror-react' typecheck",
        "typecheck:mirror-solid": "bun --filter '@hiecom/mirror-solid' typecheck",
        "typecheck:mirror-preact": "bun --filter '@hiecom/mirror-preact' typecheck",
        "typecheck:mirror-shared": "bun --filter '@hiecom/mirror-shared' typecheck",
        "typecheck:testing": "bun --filter '@hiecom/testing' typecheck",
        "build": "bun --filter '*' build",
        "build:mirror-js": "bun --filter '@hiecom/mirror-js' build",
        "build:mirror-react": "bun --filter '@hiecom/mirror-react' build",
        "build:mirror-solid": "bun --filter '@hiecom/mirror-solid' build",
        "build:mirror-preact": "bun --filter '@hiecom/mirror-preact' build",
        "build:mirror-shared": "bun --filter '@hiecom/mirror-shared' build",
        "build:testing": "bun --filter '@hiecom/testing' build",
        "test": "bun --filter '*' test",
        "test:testing": "bun --filter '@hiecom/testing' test"
    }
}