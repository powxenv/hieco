{
    "name": "hiecom",
    "private": true,
    "workspaces": [
        "packages/*",
        "apps/*",
        "examples/*"
    ],
    "scripts": {
        "fmt": "bun --filter '*' fmt",
        "fmt:web": "bun --filter '@hiecom/mirror-node' fmt",
        "fmt:api": "bun --filter '@hiecom/react-mirror-node' fmt",
        "lint": "bun --filter '*' lint",
        "lint:web": "bun --filter '@hiecom/mirror-node' lint",
        "lint:api": "bun --filter '@hiecom/react-mirror-node' lint",
        "typecheck": "bun --filter '*' typecheck",
        "typecheck:web": "bun --filter '@hiecom/mirror-node' typecheck",
        "typecheck:api": "bun --filter '@hiecom/react-mirror-node' typecheck"
    }
}